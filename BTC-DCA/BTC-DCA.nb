 RowBox[{
  RowBox[{"purchcost", "=", "0.03"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"btcusd", " ", "=", 
   RowBox[{"FinancialData", "[", 
    RowBox[{"\"\<BTC/USD\>\"", ",", 
