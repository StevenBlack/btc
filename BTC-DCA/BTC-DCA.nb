 RowBox[{
  RowBox[{"nbtcusd", "=", 
   RowBox[{"btcusd", "//", "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"currentprice", "=", 
   RowBox[{"Last", "[", 
    RowBox[{"Last", "[", "nbtcusd", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dca", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"date", "->", 
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"price", "->", 
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", 
       RowBox[{"infl", "->", 
        RowBox[{"InflationAdjust", "[", 
         RowBox[{"Quantity", "[", 
          RowBox[{"1", ",", 
           RowBox[{"DatedUnit", "[", 
            RowBox[{"\"\<USDollars\>\"", ",", 
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], "]"}], "]"}]}], ",", 
       
       RowBox[{"sats", "->", 
        RowBox[{"IntegerPart", "[", 
         RowBox[{"100000000", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "purchcost"}], ")"}], "/", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}]}]}], "|>"}], "&"}], "/@",
     "nbtcusd"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cums", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"MapIndexed", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#1", "/", "#2"}], "&"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Map", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#1", "[", "sats", "]"}], "&"}], " ", ",", " ", 
              RowBox[{"Reverse", "[", "dca", "]"}]}], "]"}], "//", 
            "Flatten"}], "//", "N"}], "//", "Accumulate"}]}], "]"}], "//", 
       "Flatten"}], ")"}], "*", 
     RowBox[{"currentprice", "/", "100000000"}]}], "//", "Reverse"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dca", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "\"\<dcaperf\>\""}], "]"}], "]"}], "=", "cums"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pv", "[", "days_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", "sats", "]"}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{"Take", "[", 
            RowBox[{"dca", ",", 
             RowBox[{"-", "days"}]}], "]"}], ")"}]}], ")"}], "//", "Total"}], 
       ")"}], "*", 
      RowBox[{"currentprice", "/", "100000000"}]}], ")"}], "/", "days"}]}], 
  ";"}], "\[IndentingNewLine]", 
