          Select[$CellContext`ddpct, And[First[
               First[#]] >= DateObject[{$CellContext`sinceyr$$, 1, 1}], 1 == 
             1]& ]; $CellContext`dlp = DateListPlot[{$CellContext`btcusds$, 
