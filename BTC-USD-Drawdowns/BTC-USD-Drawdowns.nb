             "BTC Price Drawdowns From High Peaks Since " <> 
              ToString[$CellContext`sinceyr$$], 
              "Subsection"], $CellContext`grd, 
             Spacer[20]}, Center]]; 
       If[$CellContext`sinceyr$$ == 
         2015, $CellContext`filename = 
          "BTC-USD-Drawdowns_Since_" <> ToString[$CellContext`sinceyr$$] <> 
           ".jpg"; Export[$CellContext`filename, $CellContext`output]; 
