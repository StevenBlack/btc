             RowBox[{"[", "2", "]"}], "]"}]}], 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}]]}]}], "}"}], "&"}], "/@", 
      RowBox[{"Normal", "[", "btc", "]"}]}]}], ";"}], "\n", 
